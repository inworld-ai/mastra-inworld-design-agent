    "@mastra/core": "1.38.0-alpha.5",
    "@mastra/editor": "^0.11.0-alpha.5",
    "@mastra/libsql": "^1.12.0-alpha.0",
    "@mastra/voice-inworld": "0.3.0-alpha.1",
    "hono": "^4.6.0",
    "mastra": "1.11.0-alpha.6",
    "tsx": "^4.21.0",
    "undici": "^7.27.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
