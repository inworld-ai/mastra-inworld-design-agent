# Required. Used for the realtime voice session AND the agent's text-path
# model (via Inworld's OpenAI-compatible router). The key is pre-Base64-encoded
# ("runtime key" on platform.inworld.ai) — pass verbatim, do not re-encode.
INWORLD_API_KEY=<your-pre-base64-encoded-inworld-key>

# Optional. Enables Mastra Studio at /admin (basic auth). Leave unset to
# disable the admin surface entirely.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change_me

# Optional overrides. STT + TTS use @mastra/voice-inworld's Inworld defaults.
# PORT=4111                                        # public server port
# STUDIO_PORT=4112                                 # internal Studio port (loopback only)
# INWORLD_REALTIME_MODEL=inworld/models/gemma-4-26b-a4b-it  # realtime voice LLM (default); e.g. openai/gpt-5.5, anthropic/claude-sonnet-4-6
# INWORLD_TEXT_MODEL=openai/gpt-4.1                # Studio text-chat model (Inworld router)
# DATABASE_URL=file:./data/mastra.db               # shared Studio-edits DB (both processes)
# PUBLIC_AGENT_STATUS=published                    # 'draft' = Studio saves go live without Activate
